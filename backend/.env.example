# ─────────────────────────────────────────────
#  AfriMarket Backend — Environment Variables
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/afrimarket?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OTP (set to true to log OTP to console in dev instead of sending SMS)
OTP_DEV_MODE=true
OTP_EXPIRY_SECONDS=300

# Flutterwave Payments
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret

# Paystack Payments (Nigeria / Ghana)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# M-Pesa Daraja (Kenya)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://yourdomain.com/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# Agora.io (Live Streaming)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Google Maps (SmartAddress)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Cloud Messaging (Push Notifications)
FCB_PROJECT_ID=your-firebase-project-id
FCB_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Sendy Delivery (Kenya)
SENDY_API_KEY=your-sendy-api-key
SENDY_API_USERNAME=your-sendy-username
SENDY_VENDOR_TYPE=1
SENDY_BASE_URL=https://apitest.sendyit.com/v1

# Kwik Delivery (Nigeria)
KWIK_API_KEY=your-kwik-api-key
KWIK_BASE_URL=https://staging.api.kwik.delivery

# Delivery fee defaults (in local currency)
DEFAULT_DELIVERY_FEE_KES=200
DEFAULT_DELIVERY_FEE_NGN=1500
