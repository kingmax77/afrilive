generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  RIDER
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum OrderStatus {
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum RiderDeliveryStatus {
  ASSIGNED
  PICKED_UP
  DELIVERED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  ROAD_BLOCKED
  FLOODING
  INSECURITY
  CONSTRUCTION
  ACCIDENT
  OTHER
}

// ─────────────────────────────────────────────
//  Models
// ─────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String
  role       Role     @default(BUYER)
  avatar     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  addresses       SmartAddress[]
  products        Product[]
  streamsHosted   Stream[]         @relation("SellerStreams")
  ordersBuyer     Order[]          @relation("BuyerOrders")
  ordersSeller    Order[]          @relation("SellerOrders")
  deliveries      RiderDelivery[]
  incidents       Incident[]

  @@map("users")
}

model SmartAddress {
  id                   String   @id @default(uuid())
  userId               String
  code                 String   @unique
  label                String   @default("Home")
  lat                  Float
  lng                  Float
  landmark             String?
  gateColor            String?
  floor                String?
  arrivalInstructions  String?
  photos               String[] @default([])
  deliveryNotes        String?
  confidenceScore      Int      @default(0)
  isPrimary            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("smart_addresses")
}

model Product {
  id          String   @id @default(uuid())
  sellerId    String
  name        String
  description String?
  price       Float
  currency    String   @default("KES")
  category    String?
  photos      String[] @default([])
  stockCount  Int      @default(0)
  totalSold   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller         User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders         Order[]
  pinnedInStream Stream?  @relation("PinnedProduct")

  @@map("products")
}

model Stream {
  id              String       @id @default(uuid())
  sellerId        String
  title           String
  category        String?
  status          StreamStatus @default(SCHEDULED)
  viewerCount     Int          @default(0)
  scheduledFor    DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  pinnedProductId String?      @unique
  agoraToken      String?
  thumbnailUrl    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  seller        User      @relation("SellerStreams", fields: [sellerId], references: [id], onDelete: Cascade)
  pinnedProduct Product?  @relation("PinnedProduct", fields: [pinnedProductId], references: [id])
  orders        Order[]

  @@map("streams")
}

model Order {
  id               String        @id @default(uuid())
  buyerId          String
  sellerId         String?
  productId        String?
  quantity         Int           @default(1)
  totalAmount      Float         @default(0)
  currency         String        @default("KES")
  smartAddressCode String
  deliveryFee      Float         @default(0)
  status           OrderStatus   @default(CONFIRMED)
  riderId          String?
  streamId         String?
  paymentStatus    PaymentStatus @default(PENDING)
  paymentReference String?
  paymentMethod    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  buyer        User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller       User?         @relation("SellerOrders", fields: [sellerId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  stream       Stream?       @relation(fields: [streamId], references: [id])
  smartAddress SmartAddress  @relation(fields: [smartAddressCode], references: [code])
  delivery     RiderDelivery?

  @@map("orders")
}

model RiderDelivery {
  id          String              @id @default(uuid())
  riderId     String
  orderId     String              @unique
  currentLat  Float?
  currentLng  Float?
  status      RiderDeliveryStatus @default(ASSIGNED)
  assignedAt  DateTime            @default(now())
  pickedUpAt  DateTime?
  deliveredAt DateTime?

  rider User  @relation(fields: [riderId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@map("rider_deliveries")
}

model Incident {
  id           String           @id @default(uuid())
  reporterId   String
  type         IncidentType
  severity     IncidentSeverity @default(MEDIUM)
  lat          Float
  lng          Float
  description  String?
  photoUrl     String?
  reporterRole Role
  trustScore   Int              @default(50)
  confirmations Int             @default(0)
  disputes     Int              @default(0)
  expiresAt    DateTime
  createdAt    DateTime         @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  @@map("incidents")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_codes")
}
